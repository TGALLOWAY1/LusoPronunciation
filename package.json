{
  "name": "lusopronounce",
  "version": "1.0.0",
  "description": "A Personal Pronunciation Trainer For Brazilian Portuguese",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx src/server/app.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "echo \"lint not configured\"",
    "generate:audio": "node scripts/generate_audio.js",
    "generate:word-practice": "tsx scripts/buildSyntheticWordPracticeData.ts",
    "analyze:words": "tsx scripts/analyzeWordsAndSentences.ts",
    "audio:words": "tsx scripts/generateWordAudio.ts",
    "audio:words:force": "tsx scripts/generateWordAudio.ts --force",
    "audio:words:male": "tsx scripts/generateWordAudio.ts --voice=male",
    "audio:words:female": "tsx scripts/generateWordAudio.ts --voice=female",
    "generation:pipeline": "tsx scripts/generationPipeline.ts --stage=all",
    "generate:gemini:sentences": "python3 scripts/generateGeminiSentences.py --output data/raw/gemini_sentences.csv",
    "generate:normalize:sentences": "tsx scripts/normalizeGeminiSentences.ts",
    "generate:sentences:stage0": "npm run generate:gemini:sentences && npm run generate:normalize:sentences",
    "dev:test-enrichment": "tsx scripts/devTestEnrichment.ts",
    "test": "vitest",
    "test:phase01": "vitest src/server/routes/pronunciationAssessment.contract.test.ts src/lib/audioQuality.test.ts src/hooks/useLivePronunciationPractice.test.tsx",
    "test:phase02": "vitest src/server/routes/pronunciationAssessment.contract.test.ts src/lib/audioQuality.test.ts src/hooks/useLivePronunciationPractice.test.tsx src/server/lib/audioConversion.test.ts src/lib/metricsPercentiles.test.ts src/hooks/useLivePronunciationPractice.telemetry.test.tsx",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.554.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.47.0",
    "mongoose": "^9.0.0",
    "multer": "^2.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/busboy": "^1.5.4",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.10",
    "autoprefixer": "^10.4.22",
    "busboy": "^1.6.0",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.10"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.3.0"
  }
}
