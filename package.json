{
  "name": "lusopronounce",
  "version": "1.0.0",
  "description": "A Personal Pronunciation Trainer For Brazilian Portuguese",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "generate:audio": "node scripts/generate_audio.js",
    "generate:word-practice": "tsx scripts/buildSyntheticWordPracticeData.ts",
    "analyze:words": "tsx scripts/analyzeWordsAndSentences.ts",
    "audio:words": "tsx scripts/generateWordAudio.ts",
    "audio:words:force": "tsx scripts/generateWordAudio.ts --force",
    "audio:words:male": "tsx scripts/generateWordAudio.ts --voice=male",
    "audio:words:female": "tsx scripts/generateWordAudio.ts --voice=female",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "microsoft-cognitiveservices-speech-sdk": "^1.47.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.10",
    "autoprefixer": "^10.4.22",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.10"
  }
}
