{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pronunciationTip.schema.json",
  "type": "object",
  "required": ["id", "locale", "phonemeId", "title", "instruction", "priority"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "locale": { "type": "string", "const": "pt-BR" },
    "phonemeId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "instruction": { "type": "string", "minLength": 1 },
    "commonErrors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "drillTextIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "priority": { "type": "integer", "minimum": 1, "maximum": 3 }
  }
}
