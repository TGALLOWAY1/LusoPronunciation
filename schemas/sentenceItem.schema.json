{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sentenceItem.schema.json",
  "type": "object",
  "required": [
    "id",
    "locale",
    "text",
    "normalizedText",
    "en",
    "category",
    "difficulty",
    "wordRefs",
    "azureAssessmentConfigId"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "locale": { "type": "string", "const": "pt-BR" },
    "text": { "type": "string", "minLength": 1 },
    "normalizedText": { "type": "string", "minLength": 1 },
    "en": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
    "wordRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["wordId", "tokenIndex"],
        "properties": {
          "wordId": { "type": "string", "minLength": 1 },
          "tokenIndex": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "azureAssessmentConfigId": { "type": "string", "minLength": 1 }
  }
}
