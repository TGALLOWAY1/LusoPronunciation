{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node", "vite/client"]
  },
  "include": ["vite.config.ts", "src/server/**/*.ts", "src/shared/**/*.ts", "src/lib/pronunciationUtils.ts", "src/lib/azurePronunciationNormalizer.ts", "src/types/pronunciation.ts", "src/vite-env.d.ts"]
}

